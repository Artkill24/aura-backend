# AURA Backend — Environment Variables
# Copy to .env and fill in values

# ── Visual Model (HuggingFace) ──
# Options:
#   dima806/deepfake_vs_real_image_detection  (fast, good for MVP)
#   Wvolf/ViT-Deepfake-Detection              (more accurate, slower)
VISUAL_MODEL_ID=dima806/deepfake_vs_real_image_detection

# ── API Config ──
PORT=8000
MAX_FILE_SIZE_MB=100

# ── Report Storage ──
# Local (default for MVP)
REPORT_STORAGE=local
# Future: REPORT_STORAGE=r2 for Cloudflare R2

# ── Cloudflare R2 (Phase 2) ──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=aura-reports

# ── Blockchain Notary (Phase 3) ──
# ALCHEMY_API_KEY=
# SIGNING_PRIVATE_KEY=
# CHAIN_ID=8453  # Base mainnet

# ── Auth (Phase 2) ──
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

